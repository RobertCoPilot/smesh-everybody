# Copy to .env.local and fill with your DEVELOPMENT Firebase web app config.
# Do not point local development at the production Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=smesh-everybody-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=smesh-everybody-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=smesh-everybody-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Leave empty when using a separate development Firebase project.
# Set to dev_ only when intentionally using isolated dev_* collections in another project.
NEXT_PUBLIC_FIRESTORE_COLLECTION_PREFIX=
FIRESTORE_DEV_COLLECTION_PREFIX=

# Production exports should be run only with production env values explicitly loaded in your shell.
FIRESTORE_PRODUCTION_COLLECTION_PREFIX=
